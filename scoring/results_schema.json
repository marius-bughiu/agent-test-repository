{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/agent-test-repository/scoring/results_schema.json",
  "title": "Agent Test Results",
  "description": "Schema for results.json produced by scripts/run_tests.sh",
  "type": "object",
  "required": ["schema_version", "agent", "started_at", "finished_at", "results"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0",
      "description": "Version of this schema; bumped on breaking changes."
    },
    "agent": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "description": "Human-readable agent name, e.g. 'Claude Code'." },
        "version": { "type": "string", "description": "Agent version string." },
        "model": { "type": "string", "description": "Underlying model id, if applicable." },
        "operator": { "type": "string", "description": "Who ran the tests (GitHub handle or team)." }
      },
      "additionalProperties": true
    },
    "environment": {
      "type": "object",
      "properties": {
        "os": { "type": "string" },
        "shell": { "type": "string" },
        "git_version": { "type": "string" },
        "gh_version": { "type": "string" },
        "python_version": { "type": "string" }
      },
      "additionalProperties": true
    },
    "started_at": { "type": "string", "format": "date-time" },
    "finished_at": { "type": "string", "format": "date-time" },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "status"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[0-9]{2}-[a-z0-9-]+-[0-9]{2}$",
            "description": "Test identifier, e.g. '10-basics-01'."
          },
          "status": {
            "type": "string",
            "enum": ["passed", "failed", "skipped", "errored"]
          },
          "duration_seconds": { "type": "number", "minimum": 0 },
          "message": { "type": "string", "description": "Failure reason or skip reason." },
          "skip_reason": { "type": "string", "enum": ["missing_dep", "no_fork", "unsupported_os", "user_skipped"] },
          "stdout_tail": { "type": "string", "description": "Last ~1KB of stdout for debugging." },
          "attempts": { "type": "integer", "minimum": 1, "default": 1 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
